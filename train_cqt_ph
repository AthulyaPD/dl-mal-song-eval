{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"pygments_lexer":"ipython3","nbconvert_exporter":"python","version":"3.6.4","file_extension":".py","codemirror_mode":{"name":"ipython","version":3},"name":"python","mimetype":"text/x-python"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"kernelVersion","sourceId":312754178},{"sourceType":"kernelVersion","sourceId":312755060},{"sourceType":"kernelVersion","sourceId":320236106}],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"script","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/existentialnpc/train-cqt-ph?scriptVersionId=320332386\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"cell_type":"code","source":"# %% [code]\n# Version 12 - X-Vector Alone (Chitra's Model Feature Ablation)\nimport torch\nimport os\nimport dill\nimport numpy as np\nimport pandas as pd\nimport torch.nn as nn\nfrom scipy.stats import pearsonr, spearmanr\nfrom sklearn.model_selection import KFold\nfrom torch.utils.data import Dataset, DataLoader, ConcatDataset, Subset\n\n# =========================\n# HYPERPARAMETERS & CONFIG\n# =========================\nMIN_SCORE = 2.0\nMAX_SCORE = 8.5\nBATCH_SIZE = 16        \nNUM_EPOCHS = 100\nPATIENCE = 15\n\n# ==========================================\n# DATASET GENERATION (X-VECTOR ONLY)\n# ==========================================\nclass XVectDataset(Dataset):\n    def __init__(self, dill_path):\n        with open(dill_path, 'rb') as f:\n            self.data = dill.load(f)\n\n    def __len__(self):\n        return len(self.data)\n\n    def __getitem__(self, idx):\n        item = self.data[idx]\n        xvect = torch.tensor(item['x_vector'], dtype=torch.float32)\n        target = torch.tensor(item['ratings'][0], dtype=torch.float32)\n        file_name = item['file_name'] \n        return xvect, target, file_name\n\n# ==========================================\n# REGRESSION DENSE NETWORK\n# ==========================================\nclass XVectAloneNet(nn.Module):\n    def __init__(self):\n        super(XVectAloneNet, self).__init__()\n        self.net = nn.Sequential(\n            nn.LazyLinear(512),\n            nn.BatchNorm1d(512),\n            nn.ReLU(),\n            nn.Dropout(0.3),\n            nn.Linear(512, 128),\n            nn.BatchNorm1d(128),\n            nn.ReLU(),\n            nn.Dropout(0.3),\n            nn.Linear(128, 1)\n        )\n\n    def forward(self, xvect):\n        return self.net(xvect)\n\ndef extract_tensor(output):\n    if isinstance(output, (list, tuple)):\n        output = output[0]\n    return output\n\ndef evaluate_metrics(targets, predictions):\n    targets = np.clip(targets, 0.0, 1.0).flatten()\n    predictions = np.clip(predictions, 0.0, 1.0).flatten()\n    \n    p_corr = pearsonr(targets, predictions)[0] \n    s_corr = spearmanr(targets, predictions)[0] \n    return (0.0 if np.isnan(p_corr) else p_corr), (0.0 if np.isnan(s_corr) else s_corr)\n\n# ==========================================\n# MAIN K-FOLD LOOP\n# ==========================================\ndef main():\n    device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n    print(f\"Using device: {device}\\nRunning Baseline: X-Vector Alone\", flush=True)\n\n    base_path = \"/kaggle/input/notebooks/existentialnpc/createdill-ph/dill_data\" \n    all_data = ConcatDataset([\n        XVectDataset(os.path.join(base_path, \"train.dill\")),\n        XVectDataset(os.path.join(base_path, \"val.dill\")),\n        XVectDataset(os.path.join(base_path, \"test.dill\"))\n    ])\n    \n    kf = KFold(n_splits=5, shuffle=True, random_state=42)\n    fold_pearson, fold_spearman = [], []\n    save_dir = \"./v12_xvector_alone_results\"\n    os.makedirs(save_dir, exist_ok=True)\n\n    for fold, (train_idx, val_idx) in enumerate(kf.split(np.arange(len(all_data)))):\n        print(f\"\\n🚀 STARTING X-VECTOR ALONE FOLD {fold + 1}/5\", flush=True)\n\n        train_loader = DataLoader(Subset(all_data, train_idx), batch_size=BATCH_SIZE, shuffle=True)\n        val_loader = DataLoader(Subset(all_data, val_idx), batch_size=1, shuffle=False)\n\n        model = XVectAloneNet().to(device)\n        \n        # Warmup lazy linear layers\n        d_xvect, _, _ = next(iter(train_loader))\n        _ = model(d_xvect.to(device))\n        \n        mse_loss = nn.MSELoss()\n        optimizer = torch.optim.AdamW(model.parameters(), lr=1e-4, weight_decay=1e-3)\n        \n        best_val_spearman = -1\n        epochs_no_improve = 0\n\n        for epoch in range(NUM_EPOCHS):\n            model.train()\n            total_loss = 0\n            for xvect, targets, _ in train_loader:\n                xvect = xvect.to(device)\n                targets = (targets.to(device).view(-1, 1) - MIN_SCORE) / (MAX_SCORE - MIN_SCORE)\n\n                noise = torch.randn_like(targets) * 0.02\n                smooth_targets = torch.clamp(targets + noise, 0.0, 1.0)\n\n                out = extract_tensor(model(xvect))[:, :1]\n                loss = mse_loss(out, smooth_targets)\n\n                optimizer.zero_grad()\n                loss.backward()\n                torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n                optimizer.step()\n                total_loss += loss.item()\n\n            model.eval()\n            v_preds, v_targets, v_filenames = [], [], []\n            with torch.no_grad():\n                for xvect, targets, f_names in val_loader:\n                    xvect = xvect.to(device)\n                    targets_norm = (targets.to(device).view(-1, 1) - MIN_SCORE) / (MAX_SCORE - MIN_SCORE)\n                    out = extract_tensor(model(xvect))[:, :1]\n                    v_preds.extend(out.cpu().numpy())\n                    v_targets.extend(targets_norm.cpu().numpy())\n                    v_filenames.extend(f_names)\n\n            v_p_corr, v_s_corr = evaluate_metrics(np.array(v_targets), np.array(v_preds))\n            \n            if v_s_corr > best_val_spearman:\n                best_val_spearman = v_s_corr\n                best_val_pearson = v_p_corr\n                epochs_no_improve = 0\n                \n                torch.save(model.state_dict(), f\"{save_dir}/best_xvector_alone_fold_{fold+1}.pth\")\n                \n                true_scores = (np.array(v_targets).flatten() * (MAX_SCORE - MIN_SCORE)) + MIN_SCORE\n                pred_scores = (np.array(v_preds).flatten() * (MAX_SCORE - MIN_SCORE)) + MIN_SCORE\n                \n                df_results = pd.DataFrame({\n                    \"File Name\": v_filenames, \"True Score\": np.round(true_scores, 2),\n                    \"Predicted Score\": np.round(pred_scores, 2), \"Error (Absolute)\": np.round(np.abs(true_scores - pred_scores), 2)\n                })\n                df_results.sort_values(by=\"Error (Absolute)\", ascending=False, inplace=True)\n                df_results.to_csv(f\"{save_dir}/predictions_fold_{fold+1}.csv\", index=False)\n            else:\n                epochs_no_improve += 1\n\n            if epoch % 10 == 0:\n                print(f\"Epoch {epoch} | Loss: {total_loss/len(train_loader):.4f} | Pearson: {v_p_corr:.4f} | Spearman: {v_s_corr:.4f}\", flush=True)\n\n            if epochs_no_improve >= PATIENCE: break\n\n        fold_pearson.append(best_val_pearson)\n        fold_spearman.append(best_val_spearman)\n        print(f\"✅ FOLD {fold+1} COMPLETE. Best Spearman: {best_val_spearman:.4f}\", flush=True)\n\n    print(\"\\n\" + \"X\"*30)\n    print(f\"🏆 X-VECTOR ALONE FINAL MEAN PEARSON: {np.mean(fold_pearson):.4f} (±{np.std(fold_pearson):.4f})\")\n    print(f\"🏆 X-VECTOR ALONE FINAL MEAN SPEARMAN: {np.mean(fold_spearman):.4f} (±{np.std(fold_spearman):.4f})\")\n    print(\"X\"*30)\n\nif __name__ == \"__main__\":\n    main()","metadata":{"_uuid":"593abe8e-ec23-418e-af23-2ec1434a20af","_cell_guid":"0da69aee-b9f3-49ab-a298-27480a70a57b","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false}},"outputs":[],"execution_count":null}]}